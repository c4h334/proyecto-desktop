<Window
    x:Class="proyecto_desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:proyecto_desktop.Models"
    mc:Ignorable="d"
    Title="Gestión de la Cadena de Suministros - Raúl Vega">

    <Grid>
        <Grid.Resources>
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#014681" />
            <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground" Color="#014681" />
        </Grid.Resources>

        <NavigationView x:Name="TopNavView"
                        PaneDisplayMode="Left"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        SelectionChanged="TopNavView_SelectionChanged"
                        OpenPaneLength="250">

            <NavigationView.PaneHeader>
                <StackPanel Orientation="Vertical" Padding="0,20,0,10" HorizontalAlignment="Center">
                    <Image Source="Assets/raul-vega-logo.jpg" Height="70" Margin="0,0,0,12" HorizontalAlignment="Center"/>
                    <TextBlock Text="Raúl Vega" FontWeight="SemiBold" FontSize="16" HorizontalAlignment="Center"/>
                    <TextBlock Text="Cadena de Suministros" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </NavigationView.PaneHeader>

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Productos" Tag="Productos" Icon="Shop"/>
                <NavigationViewItem Content="Usuarios" Tag="Usuarios" Icon="Contact"/>
                <NavigationViewItem Content="Proveedores" Tag="Proveedores" Icon="People"/>
            </NavigationView.MenuItems>

            <Grid Padding="32,24,32,24">

                <Grid x:Name="VistaProductos" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Gestión de Productos" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,24" Grid.Row="0"/>

                    <Grid Grid.Row="1" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                            <Button Click="AgregarProducto_Click" Style="{StaticResource AccentButtonStyle}" Background="#014681" CornerRadius="6" Height="36">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="AccentButtonBackgroundPointerOver" Color="#556BAB" />
                                    <SolidColorBrush x:Key="AccentButtonBackgroundPressed" Color="#556BAB" />
                                </Button.Resources>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="Add" />
                                    <TextBlock Text="Agregar" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>

                            <Button Click="ModificarProducto_Click" CornerRadius="6" Height="36" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="Edit" />
                                    <TextBlock Text="Modificar" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Click="EliminarProducto_Click" CornerRadius="6" Height="36" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Foreground="#D13438">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="Delete" />
                                    <TextBlock Text="Eliminar" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <AutoSuggestBox x:Name="BuscarProductoBox" 
                                        Grid.Column="1" 
                                        HorizontalAlignment="Right" 
                                        Width="250" 
                                        PlaceholderText="Buscar por código..." 
                                        QueryIcon="Find" 
                                        TextChanged="BuscarProductoBox_TextChanged"/>
                    </Grid>

                    <Grid Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Background="#556BAB" CornerRadius="8,8,0,0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="16,12">
                                <TextBlock Text="Código" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                            </Border>
                            <Border Grid.Column="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="16,12">
                                <TextBlock Text="Nombre" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                            </Border>
                            <Border Grid.Column="2" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="16,12">
                                <TextBlock Text="Descripción" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                            </Border>
                            <Border Grid.Column="3" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="16,12">
                                <TextBlock Text="Cantidad" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                            </Border>
                            <Border Grid.Column="4" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="16,12">
                                <TextBlock Text="Precio" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                            </Border>
                            <Border Grid.Column="5" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="16,12">
                                <TextBlock Text="Disponible" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                            </Border>
                            <Border Grid.Column="6" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="16,12">
                                <TextBlock Text="Descuento" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                            </Border>
                            <Border Grid.Column="7" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="16,12">
                                <TextBlock Text="Monto descuento" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                            </Border>
                            <Border Grid.Column="8" Padding="16,12">
                                <TextBlock Text="Material" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                            </Border>
                        </Grid>

                        <ListView Grid.Row="1"
                                  x:Name="ProductosListView"
                                  SelectionMode="Single"
                                  ShowsScrollingPlaceholders="True"
                                  Margin="0,0,0,8">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:Producto">
                                    <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="16,14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{x:Bind Codigo}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{x:Bind Nombre}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="2" Text="{x:Bind Descripcion}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,10,0"/>
                                            <TextBlock Grid.Column="3" Text="{x:Bind Cantidad}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="{x:Bind Precio}" VerticalAlignment="Center"/>
                                            <CheckBox Grid.Column="5" IsChecked="{x:Bind Disponible, Mode=OneWay}" IsEnabled="False" VerticalAlignment="Center" MinWidth="0" MinHeight="0" Margin="0,-6,0,0"/>
                                            <TextBlock Grid.Column="6" Text="{x:Bind Descuento}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="7" Text="{x:Bind CantDescuento}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="8" Text="{x:Bind Material}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>

                <Grid x:Name="VistaUsuarios" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Gestión de Usuarios y Roles" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,24" Grid.Row="0"/>

                    <Grid Grid.Row="1" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <AutoSuggestBox x:Name="BuscarUsuarioBox" 
                                        Grid.Column="1" 
                                        HorizontalAlignment="Right" 
                                        Width="250" 
                                        PlaceholderText="Buscar por usuario..." 
                                        QueryIcon="Find" 
                                        TextChanged="BuscarUsuarioBox_TextChanged"/>
                    </Grid>

                    <Grid Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Background="#556BAB" CornerRadius="8,8,0,0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="250"/>
                                <ColumnDefinition Width="250"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="16,12">
                                <TextBlock Text="Nombre Completo" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                            </Border>
                            <Border Grid.Column="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="16,12">
                                <TextBlock Text="Usuario" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                            </Border>
                            <Border Grid.Column="2" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="16,12">
                                <TextBlock Text="Correo Electrónico" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                            </Border>
                            <Border Grid.Column="3" Padding="16,12">
                                <TextBlock Text="Rol / Roles" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                            </Border>
                        </Grid>

                        <ListView Grid.Row="1"
                                  x:Name="UsuariosListView"
                                  SelectionMode="Single"
                                  Margin="0,0,0,8">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:Usuario">
                                    <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="16,14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200"/>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="250"/>
                                                <ColumnDefinition Width="250"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{x:Bind Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" Text="{x:Bind Username}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="2" Text="{x:Bind Email}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="3" Text="{x:Bind Roles}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>

                <Grid x:Name="VistaProveedores" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Gestión de Proveedores" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,24" Grid.Row="0"/>

                    <Grid Grid.Row="1" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                            <Button Click="AgregarProveedor_Click" Style="{StaticResource AccentButtonStyle}" Background="#014681" CornerRadius="6" Height="36">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="AccentButtonBackgroundPointerOver" Color="#556BAB" />
                                    <SolidColorBrush x:Key="AccentButtonBackgroundPressed" Color="#556BAB" />
                                </Button.Resources>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="Add" />
                                    <TextBlock Text="Agregar" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>

                            <Button Click="ModificarProveedor_Click" CornerRadius="6" Height="36" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="Edit" />
                                    <TextBlock Text="Modificar" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Click="EliminarProveedor_Click" CornerRadius="6" Height="36" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Foreground="#D13438">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="Delete" />
                                    <TextBlock Text="Eliminar" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <AutoSuggestBox x:Name="BuscarProveedorBox" 
                                        Grid.Column="1" 
                                        HorizontalAlignment="Right" 
                                        Width="250" 
                                        PlaceholderText="Buscar por identificación..." 
                                        QueryIcon="Find" 
                                        TextChanged="BuscarProveedorBox_TextChanged"/>
                    </Grid>

                    <Grid Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Padding="0" Background="#556BAB" CornerRadius="8,8,0,0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="16,12">
                                <TextBlock Text="Identificación" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                            </Border>
                            <Border Grid.Column="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="16,12">
                                <TextBlock Text="Nombre" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                            </Border>
                            <Border Grid.Column="2" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="16,12">
                                <TextBlock Text="Apellidos" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                            </Border>
                            <Border Grid.Column="3" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="16,12">
                                <TextBlock Text="Teléfono" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                            </Border>
                            <Border Grid.Column="4" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="16,12">
                                <TextBlock Text="Dirección" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                            </Border>
                            <Border Grid.Column="5" Padding="16,12">
                                <TextBlock Text="Correo" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                            </Border>
                        </Grid>

                        <ListView Grid.Row="1"
                                  x:Name="ProveedoresListView"
                                  SelectionMode="Single"
                                  Margin="0,0,0,8">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:Proveedor">
                                    <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="16,14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="180"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{x:Bind Identificacion}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{x:Bind Nombre}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="2" Text="{x:Bind Apellidos}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="3" Text="{x:Bind Tel}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="{x:Bind Direccion}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,10,0"/>
                                            <TextBlock Grid.Column="5" Text="{x:Bind Correo}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </Grid>
        </NavigationView>
    </Grid>
</Window>