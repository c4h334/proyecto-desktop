<Page
    x:Class="proyecto_desktop.Views.ProductosPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:proyecto_desktop.Models">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Gestión de Productos" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,24" Grid.Row="0"/>

        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                <Button Click="AgregarProducto_Click" Style="{StaticResource AccentButtonStyle}" Background="#014681" CornerRadius="6" Height="36">
                    <Button.Resources>
                        <SolidColorBrush x:Key="AccentButtonBackgroundPointerOver" Color="#556BAB" />
                        <SolidColorBrush x:Key="AccentButtonBackgroundPressed" Color="#556BAB" />
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Add" />
                        <TextBlock Text="Agregar" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

                <Button Click="ModificarProducto_Click" CornerRadius="6" Height="36" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Edit" />
                        <TextBlock Text="Modificar" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Click="EliminarProducto_Click" CornerRadius="6" Height="36" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Foreground="#D13438">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Delete" />
                        <TextBlock Text="Eliminar" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <AutoSuggestBox x:Name="BuscarProductoBox" 
                            Grid.Column="1" 
                            HorizontalAlignment="Right" 
                            Width="250" 
                            PlaceholderText="Buscar por código..." 
                            QueryIcon="Find" 
                            TextChanged="BuscarProductoBox_TextChanged"/>
        </Grid>

        <Grid Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Encabezado de tabla -->
            <Grid Grid.Row="0" Background="#556BAB" CornerRadius="8,8,0,0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="0.8*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="0.7*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="0.7*"/>
                    <ColumnDefinition Width="0.7*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="12,14">
                    <TextBlock Text="Img" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                </Border>
                <Border Grid.Column="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="12,12">
                    <TextBlock Text="Código" FontWeight="SemiBold" Foreground="#FFFFFF" TextTrimming="CharacterEllipsis"/>
                </Border>
                <Border Grid.Column="2" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="12,12">
                    <TextBlock Text="Nombre" FontWeight="SemiBold" Foreground="#FFFFFF" TextTrimming="CharacterEllipsis"/>
                </Border>
                <Border Grid.Column="3" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="12,12">
                    <TextBlock Text="Descripción" FontWeight="SemiBold" Foreground="#FFFFFF" TextTrimming="CharacterEllipsis"/>
                </Border>
                <Border Grid.Column="4" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="12,12">
                    <TextBlock Text="Cant." FontWeight="SemiBold" Foreground="#FFFFFF"/>
                </Border>
                <Border Grid.Column="5" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="12,12">
                    <TextBlock Text="Precio" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                </Border>
                <Border Grid.Column="6" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="12,12">
                    <TextBlock Text="Precio Final" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                </Border>
                <Border Grid.Column="7" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="12,12">
                    <TextBlock Text="Desc." FontWeight="SemiBold" Foreground="#FFFFFF"/>
                </Border>
                <Border Grid.Column="8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="12,12">
                    <TextBlock Text="Min." FontWeight="SemiBold" Foreground="#FFFFFF"/>
                </Border>
                <Border Grid.Column="9" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="12,12">
                    <TextBlock Text="Material" FontWeight="SemiBold" Foreground="#FFFFFF" TextTrimming="CharacterEllipsis"/>
                </Border>
                <Border Grid.Column="10" Padding="12,12">
                    <TextBlock Text="Disp." FontWeight="SemiBold" Foreground="#FFFFFF"/>
                </Border>
            </Grid>

            <ListView Grid.Row="1"
                      x:Name="ProductosListView"
                      SelectionMode="Single"
                      ShowsScrollingPlaceholders="True"
                      Margin="0,0,0,8">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Producto">
                        <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="0.8*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="0.7*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="0.7*"/>
                                    <ColumnDefinition Width="0.7*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <Image Grid.Column="0" Source="{x:Bind Image}" Width="36" Height="36" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{x:Bind Codigo}" VerticalAlignment="Center" Padding="12,0" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="2" Text="{x:Bind Nombre}" VerticalAlignment="Center" Padding="12,0" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="3" Text="{x:Bind Descripcion}" VerticalAlignment="Center" Padding="12,0" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="4" Text="{x:Bind Cantidad}" VerticalAlignment="Center" Padding="12,0"/>
                                <TextBlock Grid.Column="5" Text="{x:Bind Precio}" VerticalAlignment="Center" Padding="12,0"/>
                                <TextBlock Grid.Column="6" Text="{x:Bind PrecioFinal}" VerticalAlignment="Center" Padding="12,0"/>
                                <TextBlock Grid.Column="7" Text="{x:Bind Descuento}" VerticalAlignment="Center" Padding="12,0"/>
                                <TextBlock Grid.Column="8" Text="{x:Bind CantDescuento}" VerticalAlignment="Center" Padding="12,0"/>
                                <TextBlock Grid.Column="9" Text="{x:Bind Material}" VerticalAlignment="Center" Padding="12,0" TextTrimming="CharacterEllipsis"/>
                                <CheckBox Grid.Column="10" IsChecked="{x:Bind Disponible, Mode=OneWay}" IsEnabled="False" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="12,0,0,0" MinWidth="0" MinHeight="0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>