<Page
    x:Class="proyecto_desktop.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Image Source="ms-appx:///Assets/background.jpg" Stretch="UniformToFill" />
        <Grid Background="#66000000" />

        <Border Background="#E6FFFFFF" 
                CornerRadius="24" 
                BorderBrush="#80FFFFFF" 
                BorderThickness="1.5" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center" 
                Width="400" 
                Padding="32">

            <StackPanel Spacing="16">
                <TextBlock Text="Iniciar Sesión" 
                           FontSize="28" 
                           FontWeight="ExtraBold" 
                           Foreground="#111827" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,4"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,-8,0,12">
                    <TextBlock Text="¿No tienes una cuenta? " FontSize="13" Foreground="#4B5563"/>
                    <HyperlinkButton Content="Regístrate aquí" 
                                     Click="BtnRegisterLink_Click" 
                                     Padding="0"
                                     FontSize="13" 
                                     FontWeight="Medium"
                                     Foreground="#1E3A8A"
                                     VerticalAlignment="Center"/>
                </StackPanel>

                <InfoBar x:Name="ErrorBar" 
                         IsOpen="False" 
                         Severity="Error" 
                         Title="Error de acceso" 
                         Message="Acceso denegado o credenciales incorrectas." 
                         Margin="0,0,0,8"/>

                <TextBox x:Name="TxtUsername" 
                         Header="Nombre de Usuario" 
                         PlaceholderText="Tu nombre de usuario" 
                         CornerRadius="8"
                         Background="White"/>

                <PasswordBox x:Name="TxtPassword" 
                             Header="Contraseña" 
                             PlaceholderText="••••••••" 
                             CornerRadius="8"
                             Background="White"/>

                <Button x:Name="BtnLogin" 
                        Content="Ingresar" 
                        Width="336" 
                        Height="44"
                        Background="#1E3A8A" 
                        Foreground="White" 
                        CornerRadius="8" 
                        FontWeight="Bold" 
                        FontSize="15"
                        Click="BtnLogin_Click" 
                        Margin="0,12,0,0"/>

                <ProgressRing x:Name="LoadingRing" 
                              IsActive="False" 
                              HorizontalAlignment="Center" 
                              Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>