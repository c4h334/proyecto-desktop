<Page
    x:Class="proyecto_desktop.Views.RegisterAdminPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <!-- Background Image resembling the Web Page -->
        <Image Source="ms-appx:///Assets/background.jpg" Stretch="UniformToFill" />
        <!-- Dark overlay to improve readability -->
        <Grid Background="#66000000" />

        <Border Background="#E6FFFFFF" 
                CornerRadius="24" 
                BorderBrush="#80FFFFFF" 
                BorderThickness="1.5" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center" 
                Width="400" 
                Padding="32" 
                Shadow="{ThemeResource CardShadow}">
            
            <StackPanel Spacing="12">
                <!-- Back to Login Button -->
                <HyperlinkButton Click="BtnBack_Click" HorizontalAlignment="Left" Padding="0" Margin="0,0,0,8" Foreground="#1E3A8A">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Back" />
                        <TextBlock Text="Volver al Login" FontSize="13" FontWeight="SemiBold" />
                    </StackPanel>
                </HyperlinkButton>

                <TextBlock Text="Crear Cuenta Admin" 
                           FontSize="26" 
                           FontWeight="ExtraBold" 
                           Foreground="#111827" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,4"/>

                <!-- InfoBar for displaying status/error messages -->
                <InfoBar x:Name="AlertBar" IsOpen="False" Margin="0,0,0,4" />

                <!-- Input fields matching web styles -->
                <TextBox x:Name="TxtName" 
                         Header="Nombre Completo" 
                         PlaceholderText="Juan Pérez" 
                         CornerRadius="8"
                         Background="White"/>

                <TextBox x:Name="TxtUsername" 
                         Header="Nombre de Usuario" 
                         PlaceholderText="jperez123" 
                         CornerRadius="8"
                         Background="White"/>

                <TextBox x:Name="TxtEmail" 
                         Header="Email" 
                         PlaceholderText="ejemplo@correo.com" 
                         CornerRadius="8"
                         Background="White"/>

                <PasswordBox x:Name="TxtPassword" 
                             Header="Contraseña" 
                             PlaceholderText="••••••••" 
                             CornerRadius="8"
                             Background="White"/>

                <!-- Deep Blue Register Button (bg-blue-900 style) -->
                <Button x:Name="BtnRegister" 
                        Content="Registrarse" 
                        Width="336" 
                        Height="44"
                        Background="#1E3A8A" 
                        Foreground="White" 
                        CornerRadius="8" 
                        FontWeight="Bold" 
                        FontSize="15"
                        Click="BtnRegister_Click" 
                        Margin="0,16,0,0"/>

                <ProgressRing x:Name="LoadingRing" 
                              IsActive="False" 
                              HorizontalAlignment="Center" 
                              Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>